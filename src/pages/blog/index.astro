---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlocksBackground from '../../components/BlocksBackground.astro';
import { getCollection } from 'astro:content';
import { getTechColor, projectColors } from '../../lib/colors';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group posts by week
function getWeekStart(date: Date): Date {
  const d = new Date(date);
  const day = d.getDay();
  const diff = d.getDate() - day + (day === 0 ? -6 : 1);
  d.setDate(diff);
  d.setHours(0, 0, 0, 0);
  return d;
}

function formatWeekRange(start: Date): string {
  const end = new Date(start);
  end.setDate(end.getDate() + 6);
  const startStr = start.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  const endStr = end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  return `${startStr} — ${endStr}`;
}

// Add week info to each post
const postsWithWeek = posts.map(post => ({
  post,
  weekKey: getWeekStart(post.data.date).toISOString(),
  weekLabel: formatWeekRange(getWeekStart(post.data.date))
}));

const POSTS_PER_PAGE = 6;
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
---

<BaseLayout title="All Posts - Engineering Devlog">
  <BlocksBackground />
  <h1>All Posts</h1>

  {posts.length === 0 ? (
    <p class="empty">No posts yet.</p>
  ) : (
    <>
      <div class="posts-container" id="posts-container">
        {postsWithWeek.map(({ post, weekKey, weekLabel }, index) => {
          const project = post.data.project ? projectColors[post.data.project as keyof typeof projectColors] : null;
          const preview = post.data.description || post.data.patterns?.slice(0, 3).join(' • ') || '';
          const isFirstOfWeek = index === 0 || postsWithWeek[index - 1].weekKey !== weekKey;

          return (
            <>
              {isFirstOfWeek && (
                <h2 class="week-header" data-week={weekKey} data-index={index}>
                  <span class="week-label">Week of</span>
                  {weekLabel}
                </h2>
              )}
              <article class="post-item" data-index={index} data-week={weekKey}>
                <a href={`/blog/${post.slug}`} style={project ? `--project-color: ${project.color}` : ''}>
                  <div class="post-header">
                    {project && (
                      <span class="project-badge">{project.name}</span>
                    )}
                    <span class="post-date">{post.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                  </div>
                  {preview && (
                    <p class="preview">{preview}</p>
                  )}
                  {post.data.languages.length > 0 && (
                    <div class="tags">
                      {post.data.languages.slice(0, 3).map(lang => (
                        <span class="tag" style={`--tech-color: ${getTechColor(lang)}`}>{lang}</span>
                      ))}
                    </div>
                  )}
                </a>
              </article>
            </>
          );
        })}
      </div>

      {totalPages > 1 && (
        <>
          <nav class="pagination" id="pagination">
            <button class="page-btn prev" id="prev-btn" disabled>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 18l-6-6 6-6"/>
              </svg>
            </button>
            <input type="text" class="page-indicator" id="page-indicator" value={`1 . . ${totalPages}`} readonly />
            <button class="page-btn next" id="next-btn">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>
          </nav>
          <nav class="pagination-float" id="pagination-float">
            <button class="page-btn prev" id="prev-btn-float">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M15 18l-6-6 6-6"/>
              </svg>
            </button>
            <span class="page-indicator-float" id="page-indicator-float">1 . . {totalPages}</span>
            <button class="page-btn next" id="next-btn-float">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M9 18l6-6-6-6"/>
              </svg>
            </button>
          </nav>
        </>
      )}
    </>
  )}
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  .empty {
    color: var(--text-muted);
  }

  .posts-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .week-header {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    font-weight: 500;
    display: none;
  }

  .week-header.first-visible {
    margin-top: 0;
  }

  .week-header.visible {
    display: block;
  }

  .week-label {
    color: var(--text-muted);
    opacity: 0.6;
    margin-right: 0.5rem;
  }

  .post-item {
    display: none;
  }

  .post-item.visible {
    display: block;
  }

  .post-item a {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.25rem;
    background: var(--bg-card);
    border-radius: 10px;
    border: 1px solid var(--border);
    border-left: 3px solid var(--project-color, var(--border));
    transition: border-color 0.2s, transform 0.2s, background-color 0.3s ease;
  }

  .post-item a:hover {
    border-color: var(--project-color, var(--accent));
    border-left-color: var(--project-color, var(--accent));
    transform: translateX(4px);
  }

  .post-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-badge {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--project-color);
    padding: 0.2rem 0.5rem;
    background: color-mix(in srgb, var(--project-color) 10%, transparent);
    border-radius: 4px;
  }

  .post-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .preview {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .tag {
    font-size: 0.7rem;
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
    background: color-mix(in srgb, var(--tech-color) 12%, transparent);
    color: var(--tech-color);
    border: 1px solid color-mix(in srgb, var(--tech-color) 30%, transparent);
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
    padding: 1rem 0;
  }

  .page-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s, opacity 0.2s;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--accent);
    background: var(--bg-secondary);
  }

  .page-btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .page-btn svg {
    width: 18px;
    height: 18px;
    color: var(--text);
  }

  .page-indicator {
    font-size: 1.1rem;
    color: var(--text-muted);
    width: 70px;
    text-align: center;
    background: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 0.25rem;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .page-indicator:hover {
    border-color: var(--border);
  }

  .page-indicator:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--bg-card);
    cursor: text;
  }

  .pagination-float {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(100px);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
    opacity: 0;
    visibility: hidden;
    transition: transform 0.3s ease, opacity 0.3s ease, visibility 0.3s;
    z-index: 50;
  }

  .pagination-float.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    visibility: visible;
  }

  .pagination-float .page-btn {
    width: 32px;
    height: 32px;
  }

  .page-indicator-float {
    font-size: 0.95rem;
    color: var(--text-muted);
    padding: 0 0.25rem;
  }

  @media (max-width: 600px) {
    .post-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>

<script define:vars={{ totalPages, POSTS_PER_PAGE }}>
  window.__totalPages = totalPages;
  window.__postsPerPage = POSTS_PER_PAGE;
</script>

<script>
  const container = document.getElementById('posts-container');
  const postItems = container?.querySelectorAll('.post-item');
  const weekHeaders = container?.querySelectorAll('.week-header');
  const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
  const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
  const pageIndicator = document.getElementById('page-indicator') as HTMLInputElement;
  const pagination = document.getElementById('pagination');

  // Floating pagination elements
  const paginationFloat = document.getElementById('pagination-float');
  const prevBtnFloat = document.getElementById('prev-btn-float') as HTMLButtonElement;
  const nextBtnFloat = document.getElementById('next-btn-float') as HTMLButtonElement;
  const pageIndicatorFloat = document.getElementById('page-indicator-float');

  const totalPages = (window as any).__totalPages || 1;
  const postsPerPage = (window as any).__postsPerPage || 6;
  let currentPage = 1;

  function getIndicatorText() {
    return currentPage === totalPages ? `${currentPage}` : `${currentPage} . . ${totalPages}`;
  }

  function updatePagination() {
    if (!postItems || !pageIndicator) return;

    const startIndex = (currentPage - 1) * postsPerPage;
    const endIndex = startIndex + postsPerPage;

    // Track which weeks have visible posts
    const visibleWeeks = new Set<string>();

    // Show/hide posts
    postItems.forEach((post, index) => {
      if (index >= startIndex && index < endIndex) {
        post.classList.add('visible');
        const weekKey = post.getAttribute('data-week');
        if (weekKey) visibleWeeks.add(weekKey);
      } else {
        post.classList.remove('visible');
      }
    });

    // Show/hide week headers
    let firstVisibleHeader = true;
    weekHeaders?.forEach(header => {
      header.classList.remove('first-visible');
      const weekKey = header.getAttribute('data-week');
      const headerIndex = parseInt(header.getAttribute('data-index') || '0');

      let shouldShow = false;
      // Show header if its week has visible posts AND it's the first header for posts in current page range
      if (weekKey && visibleWeeks.has(weekKey) && headerIndex >= startIndex && headerIndex < endIndex) {
        shouldShow = true;
      } else if (weekKey && visibleWeeks.has(weekKey)) {
        // Check if this header's first post is visible
        const firstPostOfWeek = container?.querySelector(`.post-item[data-week="${weekKey}"].visible`);
        const firstPostIndex = firstPostOfWeek ? parseInt(firstPostOfWeek.getAttribute('data-index') || '0') : -1;
        if (firstPostIndex === startIndex || (headerIndex < startIndex && firstPostIndex >= startIndex)) {
          shouldShow = true;
        }
      }

      if (shouldShow) {
        header.classList.add('visible');
        if (firstVisibleHeader) {
          header.classList.add('first-visible');
          firstVisibleHeader = false;
        }
      } else {
        header.classList.remove('visible');
      }
    });

    // Update buttons
    prevBtn.disabled = currentPage === 1;
    nextBtn.disabled = currentPage === totalPages;

    // Update indicator
    pageIndicator.value = getIndicatorText();
    pageIndicator.readOnly = true;

    // Update floating pagination
    if (prevBtnFloat) prevBtnFloat.disabled = currentPage === 1;
    if (nextBtnFloat) nextBtnFloat.disabled = currentPage === totalPages;
    if (pageIndicatorFloat) pageIndicatorFloat.textContent = getIndicatorText();
  }

  prevBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      updatePagination();
    }
  });

  nextBtn?.addEventListener('click', () => {
    if (currentPage < totalPages) {
      currentPage++;
      updatePagination();
    }
  });

  // Click to edit page number
  pageIndicator?.addEventListener('click', () => {
    pageIndicator.readOnly = false;
    pageIndicator.value = String(currentPage);
    pageIndicator.select();
  });

  // Handle input submission
  pageIndicator?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
      const value = parseInt(pageIndicator.value);
      if (!isNaN(value) && value >= 1 && value <= totalPages) {
        currentPage = value;
      }
      updatePagination();
      pageIndicator.blur();
    } else if (e.key === 'Escape') {
      updatePagination();
      pageIndicator.blur();
    }
  });

  // Reset on blur
  pageIndicator?.addEventListener('blur', () => {
    pageIndicator.value = getIndicatorText();
    pageIndicator.readOnly = true;
  });

  // Floating pagination handlers
  prevBtnFloat?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      updatePagination();
    }
  });

  nextBtnFloat?.addEventListener('click', () => {
    if (currentPage < totalPages) {
      currentPage++;
      updatePagination();
    }
  });

  // Show/hide floating pagination based on main pagination visibility
  function updateFloatVisibility() {
    if (!pagination || !paginationFloat) return;
    const rect = pagination.getBoundingClientRect();
    const paginationHeight = rect.height;
    const viewportBottom = window.innerHeight;

    // Check if more than half of pagination is visible
    const visibleAmount = Math.min(rect.bottom, viewportBottom) - Math.max(rect.top, 0);
    const isHalfVisible = visibleAmount > paginationHeight / 2;

    paginationFloat.classList.toggle('visible', !isHalfVisible);
  }

  window.addEventListener('scroll', updateFloatVisibility, { passive: true });
  window.addEventListener('resize', updateFloatVisibility, { passive: true });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    // Don't navigate if user is typing in an input
    if (document.activeElement?.tagName === 'INPUT') return;

    if (e.key === 'ArrowLeft' && currentPage > 1) {
      currentPage--;
      updatePagination();
    } else if (e.key === 'ArrowRight' && currentPage < totalPages) {
      currentPage++;
      updatePagination();
    }
  });

  // Initial render
  updatePagination();
  updateFloatVisibility();
</script>
