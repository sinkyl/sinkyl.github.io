---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlocksBackground from '../../components/BlocksBackground.astro';
import { getCollection } from 'astro:content';
import { getTechColor, projectColors } from '../../lib/colors';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Group posts by week
function getWeekStart(date: Date): Date {
  const d = new Date(date);
  const day = d.getDay();
  const diff = d.getDate() - day + (day === 0 ? -6 : 1); // Monday as start
  d.setDate(diff);
  d.setHours(0, 0, 0, 0);
  return d;
}

function getWeekEnd(weekStart: Date): Date {
  const end = new Date(weekStart);
  end.setDate(end.getDate() + 6);
  return end;
}

function formatWeekRange(start: Date, end: Date): string {
  const startStr = start.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  const endStr = end.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  return `${startStr} — ${endStr}`;
}

const groupedPosts = posts.reduce((acc, post) => {
  const weekStart = getWeekStart(post.data.date);
  const key = weekStart.toISOString();
  if (!acc[key]) {
    acc[key] = { weekStart, posts: [] };
  }
  acc[key].posts.push(post);
  return acc;
}, {} as Record<string, { weekStart: Date; posts: typeof posts }>);

const weeks = Object.values(groupedPosts).sort(
  (a, b) => b.weekStart.valueOf() - a.weekStart.valueOf()
);
---

<BaseLayout title="All Posts - Engineering Devlog">
  <BlocksBackground />
  <h1>All Posts</h1>

  {posts.length === 0 ? (
    <p class="empty">No posts yet.</p>
  ) : (
    <div class="weeks">
      {weeks.map(({ weekStart, posts: weekPosts }) => (
        <section class="week-section">
          <h2 class="week-header">
            <span class="week-label">Week of</span>
            {formatWeekRange(weekStart, getWeekEnd(weekStart))}
          </h2>
          <ul class="post-list">
            {weekPosts.map(post => {
              const project = post.data.project ? projectColors[post.data.project as keyof typeof projectColors] : null;
              const preview = post.data.description || post.data.patterns?.slice(0, 3).join(' • ') || '';
              return (
                <li>
                  <a href={`/blog/${post.slug}`} style={project ? `--project-color: ${project.color}` : ''}>
                    <article>
                      <div class="post-header">
                        {project && (
                          <span class="project-badge">{project.name}</span>
                        )}
                      </div>
                      {preview && (
                        <p class="preview">{preview}</p>
                      )}
                      {post.data.languages.length > 0 && (
                        <div class="tags">
                          {post.data.languages.slice(0, 3).map(lang => (
                            <span class="tag" style={`--tech-color: ${getTechColor(lang)}`}>{lang}</span>
                          ))}
                        </div>
                      )}
                    </article>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      ))}
    </div>
  )}
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  .empty {
    color: var(--text-muted);
  }

  .weeks {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .week-section {
    position: relative;
  }

  .week-header {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    font-weight: 500;
  }

  .week-label {
    color: var(--text-muted);
    opacity: 0.6;
    margin-right: 0.5rem;
  }

  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-list a {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 1.25rem;
    background: var(--bg-card);
    border-radius: 10px;
    border: 1px solid var(--border);
    border-left: 3px solid var(--project-color, var(--border));
    transition: border-color 0.2s, transform 0.2s, background-color 0.3s ease;
  }

  .post-list a:hover {
    border-color: var(--project-color, var(--accent));
    border-left-color: var(--project-color, var(--accent));
    transform: translateX(4px);
  }

  .post-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .project-badge {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--project-color);
    padding: 0.2rem 0.5rem;
    background: color-mix(in srgb, var(--project-color) 10%, transparent);
    border-radius: 4px;
  }

  .preview {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .tag {
    font-size: 0.65rem;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    background: color-mix(in srgb, var(--tech-color) 12%, transparent);
    color: var(--tech-color);
    border: 1px solid color-mix(in srgb, var(--tech-color) 30%, transparent);
  }

  @media (max-width: 600px) {
    .post-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }
  }
</style>
