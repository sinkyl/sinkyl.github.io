---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChatBot from '../components/ChatBot.astro';
import Tag from '../components/Tag.astro';
import { getCollection } from 'astro:content';
import { projects } from '../lib/projects';
import { COLORS } from '../lib/theme';
import { TECH_STACK } from '../lib/constants';

const allPosts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestPost = allPosts[0];

const currentProject = projects[Math.floor(Date.now() / 86400000) % 3];

const philosophies = [
  { text: "Detail matters.", gradient: [COLORS.red, COLORS.orange] },
  { text: "Ship fast, learn faster.", gradient: [COLORS.blue, COLORS.purple] },
  { text: "Humans dream, machines iterate.", gradient: [COLORS.purple, COLORS.blue] },
  { text: "Between intent and execution lies code.", gradient: [COLORS.green, COLORS.blue] },
];
---

<BaseLayout title="sinkyl Devlog">
  <canvas id="circuit-bg"></canvas>

  <div class="bento-grid">
    <!-- Hero / About -->
    <div class="bento-card hero" style="--delay: 0">
      <span class="label">About</span>
      <h1><span class="gradient-text">Hey, I'm Sinan</span></h1>
      <p>
        Building three ambitious projects in parallel. This devlog captures the journey —
        the wins, the bugs, the architectural decisions, and everything in between.
      </p>
      <div class="hero-links">
        <a href="/blog" class="hero-link">Read the blog &rarr;</a>
      </div>
    </div>

    <!-- Status Widget -->
    <div class="bento-card status" style="--delay: 1">
      <span class="label">Now</span>
      <div class="status-content">
        <span class="status-dot" style={`--dot-color: ${currentProject.color}`}></span>
        <div>
          <p class="status-label">Currently building</p>
          <p class="status-project" style={`color: ${currentProject.color}`}>{currentProject.name}</p>
        </div>
      </div>
    </div>

    <!-- Quote 1 -->
    <div class="bento-card quote" style={`--delay: 2; --grad-start: ${philosophies[0].gradient[0]}; --grad-end: ${philosophies[0].gradient[1]}`}>
      <blockquote>{philosophies[0].text}</blockquote>
    </div>

    <!-- Projects Block -->
    <div class="bento-card projects-block" style="--delay: 3">
      <span class="label">Projects</span>
      <div class="projects-list">
        {projects.map(project => (
          <a href={`/projects/${project.id}`} class="project-item" style={`--project-color: ${project.color}`}>
            <span class="project-icon">{project.icon}</span>
            <div class="project-info">
              <h3>{project.name}</h3>
              <p>{project.shortDescription}</p>
            </div>
            <span class="project-arrow">&rarr;</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Latest Post -->
    {latestPost && (() => {
      const postProject = projects.find(p => p.id === latestPost.data.project);
      return (
        <a href={`/blog/${latestPost.slug}`} class="bento-card latest" style={`--delay: 5; --project-color: ${postProject?.color || 'var(--text-muted)'}`}>
          <span class="label">Latest</span>
          {postProject && (
            <span class="latest-project">{postProject.name}</span>
          )}
          <time datetime={latestPost.data.date.toISOString()}>
            {latestPost.data.date.toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric'
            })}
          </time>
          <h3>{latestPost.data.title}</h3>
        </a>
      );
    })()}

    <!-- Tech Stack -->
    <div class="bento-card stack" style="--delay: 6">
      <span class="label">Stack</span>
      <div class="stack-items">
        {TECH_STACK.map(tech => (
          <Tag label={tech} size="md" />
        ))}
      </div>
    </div>

    <!-- Quote 3 -->
    <div class="bento-card quote wide" style={`--delay: 7; --grad-start: ${philosophies[2].gradient[0]}; --grad-end: ${philosophies[2].gradient[1]}`}>
      <blockquote>{philosophies[2].text}</blockquote>
    </div>

  </div>

  <ChatBot />
</BaseLayout>

<style>
  #circuit-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    opacity: 0.35;
    pointer-events: none;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: minmax(100px, auto);
    grid-auto-flow: dense;
    gap: 1rem;
    padding: 3rem 0;
  }

  .bento-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    animation: fadeSlideIn 0.5s ease-out forwards;
    animation-delay: calc(var(--delay) * 0.08s);
    opacity: 0;
    transform: translateY(20px);
    transition: background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .label {
    position: absolute;
    top: 1rem;
    right: 1rem;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    opacity: 0.6;
  }

  /* Hero Card */
  .hero {
    grid-column: span 2;
    grid-row: span 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .gradient-text {
    background: linear-gradient(
      135deg,
      var(--color-slate),
      var(--color-blue),
      var(--color-orange),
      var(--color-green),
      var(--color-blue),
      var(--color-slate)
    );
    background-size: 400% 400%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradientShift 10s ease infinite;
  }

  .hero p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    max-width: 400px;
  }

  .hero-links {
    margin-top: 1.5rem;
  }

  .hero-link {
    color: var(--accent);
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }

  .hero-link:hover {
    opacity: 0.8;
  }

  /* Status Card */
  .status {
    grid-column: span 1;
    display: flex;
    align-items: center;
  }

  .status-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .status-dot {
    width: 10px;
    height: 10px;
    background: var(--dot-color);
    border-radius: 50%;
    animation: pulse 2s ease-in-out infinite;
    box-shadow: 0 0 12px var(--dot-color);
    flex-shrink: 0;
  }

  .status-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-bottom: 0.15rem;
  }

  .status-project {
    font-size: 0.95rem;
    font-weight: 600;
  }

  /* Projects Block */
  .projects-block {
    grid-column: span 2;
    grid-row: span 2;
    display: flex;
    flex-direction: column;
  }

  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 0.5rem;
    flex: 1;
    justify-content: center;
  }

  .project-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: color-mix(in srgb, var(--text) 3%, transparent);
    border: 1px solid transparent;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, background-color 0.3s ease, border-color 0.3s ease;
  }

  .project-item:hover {
    background: color-mix(in srgb, var(--text) 6%, transparent);
    border-color: var(--project-color);
    transform: translateX(4px);
  }

  .project-icon {
    font-size: 1.3rem;
    color: var(--project-color);
    flex-shrink: 0;
  }

  .project-info {
    flex: 1;
  }

  .project-info h3 {
    color: var(--project-color);
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .project-info p {
    color: var(--text-muted);
    font-size: 0.75rem;
  }

  .project-arrow {
    color: var(--project-color);
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
  }

  .project-item:hover .project-arrow {
    opacity: 1;
    transform: translateX(4px);
  }

  /* Latest Post */
  .latest {
    grid-column: span 2;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transition: transform 0.2s, background-color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .latest:hover {
    transform: translateY(-2px);
    border-color: var(--accent);
  }

  .latest-project {
    font-size: 0.7rem;
    color: var(--project-color);
    margin-bottom: 0.25rem;
    display: block;
  }

  .latest time {
    font-size: 0.65rem;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }

  .latest h3 {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.4;
    font-weight: 500;
  }

  .latest:hover h3 {
    color: var(--text);
  }

  /* Stack Card */
  .stack {
    grid-column: span 2;
  }

  .stack-items {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  /* Quote Cards */
  .quote {
    grid-column: span 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-color: color-mix(in srgb, var(--grad-start) 15%, var(--border));
  }

  .quote.wide {
    grid-column: span 2;
  }

  .quote blockquote {
    font-size: 0.9rem;
    font-style: italic;
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--grad-start) 70%, var(--text-muted)),
      color-mix(in srgb, var(--grad-end) 70%, var(--text-muted))
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-align: center;
    line-height: 1.5;
    font-weight: 500;
  }

  /* Light mode shadows */
  :global([data-theme="light"]) .bento-card {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  }

  :global([data-theme="light"]) .latest:hover {
    box-shadow:
      0 6px 16px rgba(0, 0, 0, 0.12),
      0 12px 32px rgba(0, 0, 0, 0.1);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .hero {
      grid-column: span 2;
    }

    .projects-block {
      grid-column: span 2;
      grid-row: span 1;
    }

    .latest {
      grid-column: span 2;
    }

    .stack {
      grid-column: span 2;
    }

    .quote.wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 600px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .hero,
    .status,
    .projects-block,
    .latest,
    .stack,
    .quote,
    .quote.wide {
      grid-column: span 1;
    }

    .hero h1 {
      font-size: 1.8rem;
    }

    .hide-mobile {
      display: none;
    }
  }
</style>

<script>
  import { initCircuitBackground } from '../lib/circuitBackground';
  initCircuitBackground();
</script>
