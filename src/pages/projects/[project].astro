---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlocksBackground from '../../components/BlocksBackground.astro';
import PostCard from '../../components/PostCard.astro';
import WeekHeader from '../../components/WeekHeader.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollection } from 'astro:content';
import { projects } from '../../lib/projects';
import { addWeekInfo, isFirstOfWeek } from '../../lib/weekGrouping';
import { POSTS_PER_PAGE, CONTAINER_IDS } from '../../lib/constants';

export async function getStaticPaths() {
  return projects.map(project => ({
    params: { project: project.id },
    props: { project }
  }));
}

const { project } = Astro.props;

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft && post.data.project === project.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const postsWithWeek = addWeekInfo(posts);

const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
const containerId = CONTAINER_IDS.posts;
---

<BaseLayout title={`${project.name} — Engineering Devlog`}>
  <BlocksBackground />
  <section class="header">
    <h1 style={`--project-color: ${project.color}`}>{project.name}</h1>
    <div class="description-container" id="description-container">
      <p class="project-description">
        <span class="description-preview"></span><span class="toggle-more">...more</span><span class="description-full"></span><span class="toggle-less">...less</span>
      </p>
      <script define:vars={{ description: project.description, extendedDescription: project.extendedDescription || '' }}>
        window.__projectDescription = description;
        window.__projectExtended = extendedDescription;
      </script>
    </div>
    <p class="count">{posts.length} post{posts.length !== 1 ? 's' : ''}</p>
  </section>

  {posts.length === 0 ? (
    <p class="empty">No posts yet for this project.</p>
  ) : (
    <>
      <div class="posts-container" id={containerId}>
        {postsWithWeek.map(({ post, weekKey, weekLabel }, index) => (
          <>
            {isFirstOfWeek(postsWithWeek, index) && (
              <WeekHeader weekKey={weekKey} weekLabel={weekLabel} index={index} />
            )}
            <PostCard
              slug={post.slug}
              date={post.data.date}
              languages={post.data.languages}
              description={post.data.description}
              patterns={post.data.patterns}
              project={project.id}
              showProjectBadge={false}
              showLeftBorder={false}
              tagsPosition="header"
              index={index}
              weekKey={weekKey}
            />
          </>
        ))}
      </div>

      <Pagination
        totalPages={totalPages}
        postsPerPage={POSTS_PER_PAGE}
        containerId={containerId}
      />
    </>
  )}
</BaseLayout>

<style>
  .header {
    padding-bottom: 2rem;
  }

  .header h1 {
    font-size: 2rem;
    margin: 0.5rem 0;
    color: var(--project-color);
  }

  .description-container {
    max-width: 600px;
    margin: 1rem 0;
    position: relative;
  }

  .project-description {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .toggle-more,
  .toggle-less {
    color: var(--accent);
    cursor: pointer;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .toggle-more:hover,
  .toggle-less:hover {
    opacity: 1;
  }

  .description-full,
  .toggle-less {
    display: none;
  }

  .description-container.expanded .description-full,
  .description-container.expanded .toggle-less {
    display: inline;
  }

  .description-container.expanded .toggle-more {
    display: none;
  }

  .count {
    color: var(--text-muted);
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .empty {
    color: var(--text-muted);
    font-style: italic;
  }

  .posts-container {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media (max-width: 600px) {
    .header h1 {
      font-size: 1.75rem;
    }
  }
</style>

<script>
  import { initPagination } from '../../lib/paginationController';
  import { initDescriptionToggle } from '../../lib/descriptionToggle';
  import { CONTAINER_IDS } from '../../lib/constants';

  // Description toggle
  const description = (window as any).__projectDescription || '';
  const extended = (window as any).__projectExtended || '';
  initDescriptionToggle('description-container', {
    description,
    extendedDescription: extended,
  });

  // Initialize pagination
  initPagination(CONTAINER_IDS.posts);
</script>
