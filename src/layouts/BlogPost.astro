---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, date, tags, languages, patterns, architectures } = post.data;
---

<BaseLayout title={title}>
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <time datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}
      </time>

      {(tags.length > 0 || languages.length > 0 || patterns.length > 0 || architectures.length > 0) && (
        <div class="meta">
          {languages.length > 0 && (
            <div class="meta-group">
              <span class="meta-label">Languages:</span>
              {languages.map(lang => <span class="tag lang">{lang}</span>)}
            </div>
          )}
          {patterns.length > 0 && (
            <div class="meta-group">
              <span class="meta-label">Patterns:</span>
              {patterns.map(p => <span class="tag pattern">{p}</span>)}
            </div>
          )}
          {architectures.length > 0 && (
            <div class="meta-group">
              <span class="meta-label">Architecture:</span>
              {architectures.map(a => <span class="tag arch">{a}</span>)}
            </div>
          )}
          {tags.length > 0 && (
            <div class="meta-group">
              <span class="meta-label">Tags:</span>
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      )}
    </header>

    <div class="content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  article {
    max-width: 100%;
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  time {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .meta {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .meta-label {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .tag {
    background: var(--bg-secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
    border: 1px solid var(--border);
  }

  .tag.lang {
    border-color: #f97316;
    color: #f97316;
  }

  .tag.pattern {
    border-color: #a855f7;
    color: #a855f7;
  }

  .tag.arch {
    border-color: #22c55e;
    color: #22c55e;
  }

  .content {
    line-height: 1.8;
  }

  .content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(pre) {
    margin: 1.5rem 0;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--text-muted);
    margin: 1.5rem 0;
  }

  /* Mermaid diagram styling */
  .content :global(.mermaid) {
    background: var(--bg-secondary);
    padding: 1rem;
    border-radius: 8px;
    margin: 1.5rem 0;
    text-align: center;
  }
</style>

<script is:inline>
  // Load Mermaid and render diagrams
  (async function() {
    // Find all mermaid code blocks (Astro/Shiki uses data-language attribute)
    const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"]');

    if (mermaidBlocks.length === 0) return;

    // Dynamically load Mermaid
    const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');

    mermaid.initialize({
      startOnLoad: false,
      theme: 'dark',
      themeVariables: {
        primaryColor: '#58a6ff',
        primaryTextColor: '#e6edf3',
        primaryBorderColor: '#30363d',
        lineColor: '#8b949e',
        secondaryColor: '#161b22',
        tertiaryColor: '#0d1117',
        background: '#0d1117',
        mainBkg: '#161b22',
        nodeBorder: '#30363d',
        clusterBkg: '#161b22',
        clusterBorder: '#30363d',
        titleColor: '#e6edf3',
        edgeLabelBackground: '#161b22',
      }
    });

    // Convert code blocks to mermaid divs
    mermaidBlocks.forEach((pre) => {
      const code = pre.textContent;
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = code;
      pre.replaceWith(div);
    });

    // Render all mermaid diagrams
    await mermaid.run();
  })();
</script>
