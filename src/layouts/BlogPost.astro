---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import { getProject } from '../lib/projects';

interface Props {
  post: CollectionEntry<'blog'>;
  prevPost?: CollectionEntry<'blog'> | null;
  nextPost?: CollectionEntry<'blog'> | null;
}

const { post, prevPost, nextPost } = Astro.props;
const { title, date, tags, languages, patterns, architectures } = post.data;

const prevProject = prevPost?.data.project ? getProject(prevPost.data.project) : null;
const nextProject = nextPost?.data.project ? getProject(nextPost.data.project) : null;
---

<BaseLayout title={title}>
  <article>
    <a href="#" class="back" id="back-link">&larr; Back</a>
    <header class="post-header">
      <h1>{title}</h1>
      <time datetime={date.toISOString()}>
        {date.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
        })}
      </time>

      {(tags.length > 0 || languages.length > 0 || patterns.length > 0 || architectures.length > 0) && (
        <div class="meta">
          {languages.length > 0 && (
            <div class="meta-group">
              <span class="meta-label">Languages:</span>
              {languages.map(lang => <span class="tag lang">{lang}</span>)}
            </div>
          )}
          {patterns.length > 0 && (
            <div class="meta-group">
              <span class="meta-label">Patterns:</span>
              {patterns.map(p => <span class="tag pattern">{p}</span>)}
            </div>
          )}
          {architectures.length > 0 && (
            <div class="meta-group">
              <span class="meta-label">Architecture:</span>
              {architectures.map(a => <span class="tag arch">{a}</span>)}
            </div>
          )}
          {tags.length > 0 && (
            <div class="meta-group">
              <span class="meta-label">Tags:</span>
              {tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          )}
        </div>
      )}
    </header>

    <div class="content">
      <slot />
    </div>

    {(prevPost || nextPost) && (
      <nav class:list={['post-nav', { 'single': !prevPost || !nextPost }]}>
        {nextPost && (
          <a href={`/blog/${nextPost.slug}`} class="nav-link next" style={`--project-color: ${nextProject?.color || 'var(--text-muted)'}`}>
            <span class="nav-direction">&larr; Next</span>
            <span class="nav-info">
              {nextProject && <span class="nav-project">{nextProject.name}</span>}
              {nextProject && ' · '}
              {nextPost.data.description || nextPost.data.languages?.slice(0, 2).join(', ') || ''}
              {' · '}
              {nextPost.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </span>
          </a>
        )}

        {prevPost && (
          <a href={`/blog/${prevPost.slug}`} class="nav-link prev" style={`--project-color: ${prevProject?.color || 'var(--text-muted)'}`}>
            <span class="nav-direction">Previous &rarr;</span>
            <span class="nav-info">
              {prevProject && <span class="nav-project">{prevProject.name}</span>}
              {prevProject && ' · '}
              {prevPost.data.description || prevPost.data.languages?.slice(0, 2).join(', ') || ''}
              {' · '}
              {prevPost.data.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </span>
          </a>
        )}
      </nav>
    )}
  </article>
</BaseLayout>

<style>
  article {
    max-width: 100%;
  }

  .back {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
    display: inline-block;
    text-decoration: underline;
  }

  .back:hover {
    color: var(--accent);
  }

  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  time {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .meta {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .meta-group {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .meta-label {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .tag {
    background: var(--bg-secondary);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
    border: 1px solid var(--border);
  }

  .tag.lang {
    border-color: #f97316;
    color: #f97316;
  }

  .tag.pattern {
    border-color: #a855f7;
    color: #a855f7;
  }

  .tag.arch {
    border-color: #22c55e;
    color: #22c55e;
  }

  .content {
    line-height: 1.8;
  }

  .content :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .content :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(pre) {
    margin: 1.5rem 0;
  }

  .content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--text-muted);
    margin: 1.5rem 0;
  }

  /* Mermaid diagram styling */
  /* Show subtle loading skeleton while mermaid loads */
  .content :global(pre[data-language="mermaid"]) {
    position: relative;
    min-height: 120px;
    border-radius: 8px;
    overflow: hidden;
    color: transparent;
    user-select: none;
  }

  .content :global(pre[data-language="mermaid"])::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--bg-secondary) 0%,
      color-mix(in srgb, var(--border) 50%, var(--bg-secondary)) 50%,
      var(--bg-secondary) 100%
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .content :global(.mermaid) {
    background: var(--bg-secondary);
    padding: 1rem;
    border-radius: 8px;
    margin: 1.5rem 0;
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .content :global(.mermaid[data-processed="true"]) {
    opacity: 1;
  }

  /* Post navigation */
  .post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    margin-top: 3rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }

  .post-nav.single {
    justify-content: center;
  }

  .post-nav.single .nav-link {
    margin-left: 0;
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s;
  }

  .nav-link.prev {
    margin-left: auto;
  }

  .nav-direction {
    color: var(--text-muted);
    white-space: nowrap;
  }

  .nav-link:hover .nav-direction {
    color: var(--project-color);
  }

  .nav-info {
    color: var(--text-muted);
    opacity: 0.8;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 320px;
  }

  .nav-project {
    transition: color 0.2s;
  }

  .nav-link:hover .nav-project {
    color: var(--project-color);
  }

  @media (max-width: 600px) {
    .post-nav {
      flex-direction: column;
      gap: 1rem;
    }

    .nav-link {
      align-items: flex-start;
    }

    .nav-link.next {
      margin-left: 0;
    }

    .nav-info {
      max-width: 100%;
    }
  }
</style>

<script>
  import { initMermaidRenderer } from '../lib/mermaidRenderer';
  import { initBackNavigation } from '../lib/backNavigation';

  initMermaidRenderer();
  initBackNavigation();
</script>
