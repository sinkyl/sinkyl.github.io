---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Engineering devlog' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="logo" aria-label="Home">
          <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Central node triangle (smaller) -->
            <polygon points="20,9 25,18 15,18" fill="#61afef" opacity="0.9"/>
            <!-- Left module (point at top, flat base at bottom) -->
            <polygon points="15,31 19,31 17,25" fill="#c678dd" opacity="0.8"/>
            <!-- Right module (point at top, flat base at bottom) -->
            <polygon points="21,31 25,31 23,25" fill="#c678dd" opacity="0.8"/>
            <!-- Left flame -->
            <polygon points="16,31 18,31 17,35" fill="#d19a66" opacity="0.9"/>
            <!-- Right flame -->
            <polygon points="22,31 24,31 23,35" fill="#d19a66" opacity="0.9"/>
            <!-- Connection lines -->
            <line x1="20" y1="18" x2="20" y2="21" stroke="#61afef" stroke-width="1" opacity="0.6"/>
            <line x1="20" y1="21" x2="17" y2="25" stroke="#61afef" stroke-width="1" opacity="0.6"/>
            <line x1="20" y1="21" x2="23" y2="25" stroke="#61afef" stroke-width="1" opacity="0.6"/>
            <!-- Node points -->
            <circle cx="20" cy="21" r=".8" fill="#e6edf3"/>
            <circle cx="17" cy="25" r=".8" fill="#e6edf3"/>
            <circle cx="23" cy="25" r=".8" fill="#e6edf3"/>
          </svg>
        </a>
        <div class="nav-links">
          <a href="/" class:list={['nav-link', { active: currentPath === '/' }]}>
            <span class="nav-text">Home<span class="link-indicator"></span></span>
          </a>
          <a href="/blog" class:list={['nav-link', { active: currentPath.startsWith('/blog') }]}>
            <span class="nav-text">Blog<span class="link-indicator"></span></span>
          </a>
          <div class="nav-dropdown" id="projects-dropdown">
            <button type="button" class:list={['nav-link', 'dropdown-toggle', { active: currentPath.startsWith('/projects') }]}>
              <span class="nav-text">Projects<span class="link-indicator"></span></span>
              <svg class="dropdown-arrow" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 5l3 3 3-3"/>
              </svg>
            </button>
            <div class="dropdown-menu">
              <a href="/projects/xtranodly" class="dropdown-item" style="--project-color: #61afef">
                <span class="dropdown-dot"></span>
                xtranodly.ai
              </a>
              <a href="/projects/bazaar" class="dropdown-item" style="--project-color: #d19a66">
                <span class="dropdown-dot"></span>
                Bazaar.Shop
              </a>
              <a href="/projects/spatium" class="dropdown-item" style="--project-color: #c678dd">
                <span class="dropdown-dot"></span>
                Spatium.ai
              </a>
            </div>
          </div>
        </div>
        <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} - sinkyl Devlog</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    /* Dark theme (default) - pearl dark */
    --bg: #151719;
    --bg-secondary: #1e2227;
    --bg-card: rgba(30, 34, 39, 0.95);
    --text: #e6edf3;
    --text-muted: #9ca3af;
    --accent: #60a5fa;
    --border: #2e3339;
  }

  [data-theme="light"] {
    /* Light theme - pearl white */
    --bg: #f8f7f4;
    --bg-secondary: #fdfcfa;
    --bg-card: rgba(253, 252, 250, 0.95);
    --text: #1f2328;
    --text-muted: #656d76;
    --accent: #0969da;
    --border: #e0ddd8;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: system-ui, -apple-system, sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    border-bottom: 1px solid var(--border);
  }

  header:has(nav) {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--bg) 85%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  nav {
    display: flex;
    gap: 1.5rem;
    align-items: stretch;
    padding: 0 2rem;
  }

  .nav-links {
    position: relative;
    display: flex;
    gap: 1.5rem;
    align-items: stretch;
    padding: 0 1.5rem;
    margin: 0 -1.5rem;
  }

  .nav-link {
    position: relative;
    color: var(--text);
    text-decoration: none;
    padding: 1rem 0;
    display: flex;
    align-items: center;
    transition: color 0.2s;
  }

  .nav-text {
    position: relative;
  }

  .nav-link.active {
    color: var(--accent);
  }

  .link-indicator {
    position: absolute;
    bottom: -4px;
    left: 0;
    height: 2px;
    width: 0;
    background: var(--accent);
    border-radius: 1px;
  }


  .nav-dropdown {
    position: relative;
    display: flex;
    align-items: stretch;
  }

  .nav-dropdown .nav-link {
    gap: 0.3rem;
  }

  .dropdown-toggle {
    background: none;
    border: none;
    font: inherit;
    cursor: pointer;
  }

  .dropdown-arrow {
    width: 12px;
    height: 12px;
    margin-top: 0.33em;
    transition: transform 0.2s;
  }

  .nav-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(8px);
    min-width: 160px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, transform 0.2s, visibility 0.2s;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .nav-dropdown.open .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    color: var(--text);
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.9rem;
    transition: background 0.15s;
  }

  .dropdown-item:hover {
    background: var(--bg-secondary);
    color: var(--project-color);
  }

  .dropdown-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--project-color);
    opacity: 0.7;
  }

  .dropdown-item:hover .dropdown-dot {
    opacity: 1;
  }

  .theme-toggle {
    margin: 1rem 0;
    margin-left: auto;
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, background 0.2s;
  }

  .theme-toggle:hover {
    border-color: var(--accent);
    background: var(--bg-secondary);
  }

  .theme-toggle svg {
    width: 18px;
    height: 18px;
    color: var(--text);
  }

  .theme-toggle .icon-moon {
    display: none;
  }

  [data-theme="light"] .theme-toggle .icon-sun {
    display: none;
  }

  [data-theme="light"] .theme-toggle .icon-moon {
    display: block;
  }

  nav a.logo {
    display: flex;
    align-items: center;
    margin-right: 1rem;
    padding: 0.5rem 0;
  }

  nav a.logo svg {
    width: 45px;
    height: 45px;
    animation: none;
    transition: transform 0.5s ease-out, filter 0.5s ease-out;
  }

  nav a.logo:hover svg {
    transform: translateY(-8px) scale(1.05);
    filter: drop-shadow(0 10px 15px rgba(97, 175, 239, 0.4));
    animation: rocketFly 2s ease-in-out infinite;
    animation-delay: 0.3s;
  }

  @keyframes rocketFly {
    0%, 100% {
      transform: translateY(-8px) scale(1.05) rotate(-3deg);
    }
    50% {
      transform: translateY(-8px) scale(1.05) rotate(3deg);
    }
  }

  main {
    flex: 1;
    padding: 2rem;
    max-width: 900px;
    margin: 0 auto;
    width: 100%;
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 1rem 2rem;
    text-align: center;
    color: var(--text-muted);
  }

  a {
    color: var(--accent);
  }

  pre {
    background: var(--bg-secondary);
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
  }

  code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
  }
</style>

<script is:inline>
  // Theme toggle - runs immediately to prevent flash
  (function() {
    const stored = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const theme = stored || (prefersDark ? 'dark' : 'light');

    if (theme === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    }
  })();
</script>

<script>
  const toggle = document.getElementById('theme-toggle');

  toggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme');
    const next = current === 'light' ? 'dark' : 'light';

    if (next === 'light') {
      document.documentElement.setAttribute('data-theme', 'light');
    } else {
      document.documentElement.removeAttribute('data-theme');
    }

    localStorage.setItem('theme', next);
  });

  // Projects dropdown toggle
  const projectsDropdown = document.getElementById('projects-dropdown');
  const dropdownToggle = projectsDropdown?.querySelector('.dropdown-toggle');

  dropdownToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    projectsDropdown?.classList.toggle('open');
  });

  document.addEventListener('click', (e) => {
    if (projectsDropdown?.classList.contains('open') && !projectsDropdown.contains(e.target as Node)) {
      projectsDropdown.classList.remove('open');
    }
  });

  // Nav indicator - line passes "behind" the gap between links
  const navLinksContainer = document.querySelector('.nav-links') as HTMLElement;
  const links = Array.from(document.querySelectorAll('.nav-link')) as HTMLElement[];
  const textSpans = Array.from(document.querySelectorAll('.nav-text')) as HTMLElement[];
  const indicators = textSpans.map(span => span.querySelector('.link-indicator') as HTMLElement);
  const activeIndex = links.findIndex(link => link.classList.contains('active'));
  let lastMouseX = 0;

  // Get offset relative to nav-links container
  function getOffsetLeft(el: HTMLElement): number {
    const containerRect = navLinksContainer.getBoundingClientRect();
    const elRect = el.getBoundingClientRect();
    return elRect.left - containerRect.left;
  }

  function setIndicatorAnchor(ind: HTMLElement, anchor: 'left' | 'right') {
    if (anchor === 'left') {
      ind.style.left = '0';
      ind.style.right = 'auto';
    } else {
      ind.style.left = 'auto';
      ind.style.right = '0';
    }
  }

  function resetToActive(animate = true) {
    indicators.forEach((ind, i) => {
      if (!ind) return;
      ind.style.transition = animate ? 'width 0.25s ease-out' : 'none';
      setIndicatorAnchor(ind, 'left');
      ind.style.width = i === activeIndex ? '100%' : '0';
    });
  }

  // Set initial state
  resetToActive(false);

  // Track mouse position within nav-links
  navLinksContainer?.addEventListener('mousemove', (e) => {
    if (links.length < 2) return;

    const containerRect = navLinksContainer.getBoundingClientRect();
    const mouseX = e.clientX - containerRect.left;
    const movingRight = mouseX > lastMouseX;
    lastMouseX = mouseX;

    const firstLink = links[0];
    const lastLink = links[links.length - 1];
    const firstLinkStart = getOffsetLeft(firstLink);
    const lastLinkEnd = getOffsetLeft(lastLink) + lastLink.offsetWidth;

    // Check if in left edge zone (before first link)
    // Skip animation if first link is the active one
    if (mouseX < firstLinkStart && activeIndex !== 0) {
      const edgeZoneWidth = firstLinkStart; // The padding zone width
      const distanceIntoZone = firstLinkStart - mouseX;
      const squeezeProgress = Math.min(distanceIntoZone / edgeZoneWidth, 1);
      const squeezeWidth = (1 - squeezeProgress) * 100;
      const activeWidth = squeezeProgress * 100;

      indicators.forEach((ind, j) => {
        if (!ind) return;
        ind.style.transition = 'none';
        if (j === 0) {
          // First link: anchor right so it squeezes from the left
          setIndicatorAnchor(ind, 'right');
          ind.style.width = `${squeezeWidth}%`;
        } else if (j === activeIndex) {
          // Active link: grows from the left as first link squeezes
          setIndicatorAnchor(ind, 'left');
          ind.style.width = `${activeWidth}%`;
        } else {
          ind.style.width = '0';
        }
      });
      return;
    }

    // Check if in right edge zone (after last link)
    // Skip animation if last link is the active one
    if (mouseX > lastLinkEnd && activeIndex !== links.length - 1) {
      const containerWidth = navLinksContainer.offsetWidth;
      const edgeZoneWidth = containerWidth - lastLinkEnd; // The padding zone width
      const distanceIntoZone = mouseX - lastLinkEnd;
      const squeezeProgress = Math.min(distanceIntoZone / edgeZoneWidth, 1);
      const squeezeWidth = (1 - squeezeProgress) * 100;
      const activeWidth = squeezeProgress * 100;

      indicators.forEach((ind, j) => {
        if (!ind) return;
        ind.style.transition = 'none';
        if (j === links.length - 1) {
          // Last link: anchor left so it squeezes from the right
          setIndicatorAnchor(ind, 'left');
          ind.style.width = `${squeezeWidth}%`;
        } else if (j === activeIndex) {
          // Active link: grows from the right as last link squeezes
          setIndicatorAnchor(ind, 'right');
          ind.style.width = `${activeWidth}%`;
        } else {
          ind.style.width = '0';
        }
      });
      return;
    }

    // Find which link we're over or in gap between
    for (let i = 0; i < links.length; i++) {
      const link = links[i];
      const textSpan = textSpans[i];

      // Link boundaries (larger hover area) - using getBoundingClientRect for accuracy
      const linkStart = getOffsetLeft(link);
      const linkEnd = linkStart + link.offsetWidth;

      // Text boundaries (for gap calculation)
      const textStart = getOffsetLeft(textSpan);
      const textEnd = textStart + textSpan.offsetWidth;

      // Mouse is over this link's hover area
      if (mouseX >= linkStart && mouseX <= linkEnd) {
        indicators.forEach((ind, j) => {
          if (!ind) return;
          ind.style.transition = 'width 0.15s ease-out';
          setIndicatorAnchor(ind, 'left');
          ind.style.width = j === i ? '100%' : '0';
        });
        return;
      }

      // Check if in gap between text areas (after link hover area)
      if (i < links.length - 1) {
        const nextLink = links[i + 1];
        const nextTextSpan = textSpans[i + 1];
        const nextLinkStart = getOffsetLeft(nextLink);
        const nextTextStart = getOffsetLeft(nextTextSpan);

        const gapStart = textEnd;
        const gapEnd = nextTextStart;

        if (mouseX > linkEnd && mouseX < nextLinkStart) {
          // In the actual gap between hover areas - calculate based on text positions
          const progress = (mouseX - gapStart) / (gapEnd - gapStart);
          const clampedProgress = Math.max(0, Math.min(1, progress));

          // Round to clean values near edges to avoid lingering pixels
          const leftWidth = clampedProgress > 0.95 ? 0 : (1 - clampedProgress) * 100;
          const rightWidth = clampedProgress < 0.05 ? 0 : clampedProgress * 100;

          indicators.forEach((ind, j) => {
            if (!ind) return;
            ind.style.transition = 'none';

            if (j === i) {
              // Left link: anchor right so it shrinks/grows from the left edge
              setIndicatorAnchor(ind, 'right');
              ind.style.width = `${leftWidth}%`;
            } else if (j === i + 1) {
              // Right link: anchor left so it shrinks/grows from the right edge
              setIndicatorAnchor(ind, 'left');
              ind.style.width = `${rightWidth}%`;
            } else {
              ind.style.width = '0';
            }
          });
          return;
        }
      }
    }
  });

  // Return to active link when leaving nav
  navLinksContainer?.addEventListener('mouseleave', () => {
    resetToActive(true);
  });
</script>
