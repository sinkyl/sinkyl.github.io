---
// Simple FAQ Chat Bot - No AI, just pattern matching
const faqData = {
  greetings: ['hi', 'hello', 'hey', 'howdy', 'hola'],
  about: ['who', 'about', 'sinan', 'yourself', 'introduce'],
  projects: ['project', 'working', 'building', 'xtranodly', 'bazaar', 'spatium'],
  stack: ['stack', 'tech', 'language', 'tool', 'use', 'code'],
  experience: ['experience', 'background', 'career', 'work'],
  contact: ['contact', 'reach', 'email', 'hire', 'connect'],
  blog: ['blog', 'devlog', 'post', 'write', 'article'],
};

const responses = {
  greetings: "Hey there! I'm a simple bot here to answer questions about Sinan. Ask me about his projects, tech stack, or background!",
  about: "Sinan is a software engineer building three ambitious projects in parallel. He loves systems programming, distributed architectures, and creating tools that empower developers. This devlog captures his journey — the wins, the bugs, and everything in between.",
  projects: "Sinan is currently building three projects:\n\n◈ <a href=\"/projects/xtranodly\" target=\"_blank\">xtranodly.ai</a> — A visual node-based graph system for AI workflows and automation\n\n◉ <a href=\"/projects/bazaar\" target=\"_blank\">Bazaar.Shop</a> — A multi-tenant marketplace with PCI-DSS compliant payments and SSO\n\n◎ <a href=\"/projects/spatium\" target=\"_blank\">Spatium.ai</a> — Spatial computing for immersive 3D experiences",
  stack: "Sinan's tech stack includes:\n\n• **C#/.NET** — Backend services, microservices\n• **Rust** — Systems programming, performance-critical code\n• **Python** — AI/ML, scripting\n• **TypeScript** — Frontend, tooling\n• **Tauri** — Desktop apps\n• **gRPC** — Service communication\n• **Docker** — Containerization",
  experience: "Sinan has experience building complex distributed systems, marketplace platforms, and developer tools. His focus is on clean architecture, performance, and shipping quality software.",
  contact: "You can explore Sinan's work through this devlog. Check out the projects section or read the blog posts to see what he's building!",
  blog: "This devlog documents Sinan's weekly progress across all three projects. Each post covers architectural decisions, technical challenges, and lessons learned. Check out /blog for all posts!",
  unknown: "I'm not sure about that one! Try asking about:\n• Who Sinan is\n• His projects (xtranodly, Bazaar, Spatium)\n• His tech stack\n• The blog/devlog",
};
---

<div id="chat-widget" class="chat-widget">
  <button id="chat-toggle" class="chat-toggle" aria-label="Open chat">
    <svg class="icon-chat" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
      <!-- Sound wave bars -->
      <line x1="4" y1="12" x2="4" y2="12" class="wave-bar wave-1"/>
      <line x1="8" y1="9" x2="8" y2="15" class="wave-bar wave-2"/>
      <line x1="12" y1="5" x2="12" y2="19" class="wave-bar wave-3"/>
      <line x1="16" y1="9" x2="16" y2="15" class="wave-bar wave-4"/>
      <line x1="20" y1="12" x2="20" y2="12" class="wave-bar wave-5"/>
    </svg>
    <svg class="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="18" y1="6" x2="6" y2="18"/>
      <line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <div id="chat-panel" class="chat-panel">
    <div class="chat-header">
      <div class="chat-header-info">
        <span class="chat-avatar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
            <line x1="4" y1="12" x2="4" y2="12" class="avatar-wave wave-1"/>
            <line x1="8" y1="9" x2="8" y2="15" class="avatar-wave wave-2"/>
            <line x1="12" y1="5" x2="12" y2="19" class="avatar-wave wave-3"/>
            <line x1="16" y1="9" x2="16" y2="15" class="avatar-wave wave-4"/>
            <line x1="20" y1="12" x2="20" y2="12" class="avatar-wave wave-5"/>
          </svg>
        </span>
        <div>
          <h3>Ask About Sinan</h3>
          <span class="chat-status">FAQ Bot</span>
        </div>
      </div>
    </div>

    <div id="chat-messages" class="chat-messages">
      <button id="suggestions-toggle" class="suggestions-toggle" aria-label="Show suggestions">?</button>

      <div id="suggestions-panel" class="suggestions-panel">
        <span class="suggestions-label">Try asking:</span>
        <div class="suggestions-list">
          <button class="suggestion-btn" data-question="Who is Sinan?">Who is Sinan?</button>
          <button class="suggestion-btn" data-question="What projects is he building?">What projects?</button>
          <button class="suggestion-btn" data-question="What's his tech stack?">Tech stack?</button>
          <button class="suggestion-btn" data-question="Tell me about the blog">About the blog?</button>
        </div>
      </div>

      <div class="message bot">
        <div class="message-content">
          Hey! I'm here to answer questions about Sinan. Try asking:
          <ul>
            <li><button class="inline-suggestion" data-question="Who is Sinan?">Who is Sinan?</button></li>
            <li><button class="inline-suggestion" data-question="What projects is he building?">What projects is he building?</button></li>
            <li><button class="inline-suggestion" data-question="What's his tech stack?">What's his tech stack?</button></li>
          </ul>
        </div>
      </div>
    </div>

    <form id="chat-form" class="chat-input-form">
      <input
        type="text"
        id="chat-input"
        placeholder="Ask a question..."
        autocomplete="off"
      />
      <button type="submit" aria-label="Send message">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="22" y1="2" x2="11" y2="13"/>
          <polygon points="22 2 15 22 11 13 2 9 22 2"/>
        </svg>
      </button>
    </form>
  </div>
</div>

<style>
  .chat-widget {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 1000;
    font-family: inherit;
  }

  .chat-toggle {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #1a1d23, #2d3748);
    border: 1px solid rgba(97, 175, 239, 0.3);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s, background 0.3s;
  }

  :global([data-theme="light"]) .chat-toggle {
    background: linear-gradient(135deg, #f8f7f4, #e8e6e1);
    border-color: rgba(9, 105, 218, 0.3);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.8);
  }

  .chat-toggle:hover {
    transform: scale(1.05);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    border-color: rgba(97, 175, 239, 0.5);
  }

  :global([data-theme="light"]) .chat-toggle:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.9);
    border-color: rgba(9, 105, 218, 0.5);
  }

  .chat-toggle svg {
    width: 24px;
    height: 24px;
    color: #61afef;
  }

  :global([data-theme="light"]) .chat-toggle svg {
    color: #0969da;
  }

  .chat-toggle .icon-close {
    display: none;
  }

  .chat-widget.open .chat-toggle .icon-chat {
    display: none;
  }

  .chat-widget.open .chat-toggle .icon-close {
    display: block;
  }

  /* Sound wave animation */
  .wave-bar {
    transform-origin: center;
  }

  .chat-toggle:not(:hover) .wave-1 {
    animation: waveOuter 1.2s ease-in-out infinite;
    animation-delay: 0s;
  }

  .chat-toggle:not(:hover) .wave-2 {
    animation: waveInner 0.8s ease-in-out infinite;
    animation-delay: 0.1s;
  }

  .chat-toggle:not(:hover) .wave-3 {
    animation: waveCenter 0.6s ease-in-out infinite;
    animation-delay: 0s;
  }

  .chat-toggle:not(:hover) .wave-4 {
    animation: waveInner 0.8s ease-in-out infinite;
    animation-delay: 0.2s;
  }

  .chat-toggle:not(:hover) .wave-5 {
    animation: waveOuter 1.2s ease-in-out infinite;
    animation-delay: 0.1s;
  }

  .chat-toggle:hover .wave-1 {
    animation: waveOuterActive 0.5s ease-in-out infinite;
  }

  .chat-toggle:hover .wave-2 {
    animation: waveInnerActive 0.4s ease-in-out infinite;
    animation-delay: 0.05s;
  }

  .chat-toggle:hover .wave-3 {
    animation: waveCenterActive 0.3s ease-in-out infinite;
  }

  .chat-toggle:hover .wave-4 {
    animation: waveInnerActive 0.4s ease-in-out infinite;
    animation-delay: 0.1s;
  }

  .chat-toggle:hover .wave-5 {
    animation: waveOuterActive 0.5s ease-in-out infinite;
    animation-delay: 0.05s;
  }

  @keyframes waveOuter {
    0%, 100% { transform: scaleY(0.3); opacity: 0.5; }
    50% { transform: scaleY(0.8); opacity: 0.8; }
  }

  @keyframes waveInner {
    0%, 100% { transform: scaleY(0.6); opacity: 0.7; }
    50% { transform: scaleY(1); opacity: 1; }
  }

  @keyframes waveCenter {
    0%, 100% { transform: scaleY(0.7); opacity: 0.8; }
    50% { transform: scaleY(1.1); opacity: 1; }
  }

  @keyframes waveOuterActive {
    0%, 100% { transform: scaleY(0.5); opacity: 0.7; }
    50% { transform: scaleY(1.2); opacity: 1; }
  }

  @keyframes waveInnerActive {
    0%, 100% { transform: scaleY(0.7); opacity: 0.8; }
    50% { transform: scaleY(1.3); opacity: 1; }
  }

  @keyframes waveCenterActive {
    0%, 100% { transform: scaleY(0.8); opacity: 0.9; }
    50% { transform: scaleY(1.4); opacity: 1; }
  }

  .chat-panel {
    position: absolute;
    bottom: 70px;
    right: 0;
    width: 340px;
    max-height: 450px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    display: none;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
    animation: slideUp 0.25s ease-out;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  @keyframes slideUp {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .chat-widget.open .chat-panel {
    display: flex;
  }

  .chat-header {
    padding: 1rem;
    border-bottom: 1px solid var(--border);
    background: var(--bg);
  }

  .chat-header-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .chat-avatar {
    width: 36px;
    height: 36px;
    background: linear-gradient(135deg, #1a1d23, #2d3748);
    border: 1px solid rgba(97, 175, 239, 0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    transition: background 0.3s, border-color 0.3s, box-shadow 0.3s;
  }

  :global([data-theme="light"]) .chat-avatar {
    background: linear-gradient(135deg, #f8f7f4, #e8e6e1);
    border-color: rgba(9, 105, 218, 0.3);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .chat-avatar svg {
    width: 18px;
    height: 18px;
    color: #61afef;
    transition: color 0.3s;
  }

  :global([data-theme="light"]) .chat-avatar svg {
    color: #0969da;
  }

  .avatar-wave {
    transform-origin: center;
  }

  .avatar-wave.wave-1 {
    animation: waveOuter 1.2s ease-in-out infinite;
  }

  .avatar-wave.wave-2 {
    animation: waveInner 0.8s ease-in-out infinite;
    animation-delay: 0.1s;
  }

  .avatar-wave.wave-3 {
    animation: waveCenter 0.6s ease-in-out infinite;
  }

  .avatar-wave.wave-4 {
    animation: waveInner 0.8s ease-in-out infinite;
    animation-delay: 0.2s;
  }

  .avatar-wave.wave-5 {
    animation: waveOuter 1.2s ease-in-out infinite;
    animation-delay: 0.1s;
  }

  .chat-header h3 {
    font-size: 0.9rem;
    margin: 0;
    color: var(--text);
  }

  .chat-status {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-height: 300px;
  }

  .message {
    max-width: 85%;
    animation: fadeIn 0.2s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .message.bot {
    align-self: flex-start;
  }

  .message.user {
    align-self: flex-end;
  }

  .message-content {
    padding: 0.75rem 1rem;
    border-radius: 12px;
    font-size: 0.85rem;
    line-height: 1.5;
  }

  .message.bot .message-content {
    background: rgba(97, 175, 239, 0.1);
    border: 1px solid rgba(97, 175, 239, 0.2);
    color: var(--text);
  }

  .message.bot .message-content a {
    color: #61afef;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .message.bot .message-content a:hover {
    color: #c678dd;
    text-decoration: underline;
  }

  .message.user .message-content {
    background: linear-gradient(135deg, #61afef, #c678dd);
    color: white;
  }

  .message-content ul {
    margin: 0.5rem 0 0 0;
    padding-left: 0;
    list-style: none;
  }

  .message-content li {
    margin: 0.25rem 0;
  }

  .inline-suggestion {
    background: none;
    border: none;
    color: #61afef;
    cursor: pointer;
    font-size: inherit;
    padding: 0;
    text-align: left;
    transition: color 0.2s;
  }

  .inline-suggestion:hover {
    color: #c678dd;
    text-decoration: underline;
  }

  /* Suggestions Toggle */
  .suggestions-toggle {
    position: absolute;
    top: 5rem;
    right: 0.5rem;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: rgba(97, 175, 239, 0.1);
    border: 1px solid rgba(97, 175, 239, 0.3);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    z-index: 10;
    font-size: 1rem;
    font-weight: 600;
    color: #61afef;
  }

  .suggestions-toggle:hover {
    background: rgba(97, 175, 239, 0.2);
    border-color: #61afef;
  }

  .suggestions-toggle.active {
    background: #e06c75;
    border-color: transparent;
    color: white;
  }

  /* Suggestions Panel */
  .suggestions-panel {
    display: none;
    position: absolute;
    top: 5rem;
    right: 0.5rem;
    left: 0.5rem;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.75rem;
    z-index: 5;
    animation: fadeIn 0.2s ease-out;
  }

  .suggestions-panel.show {
    display: block;
  }

  .suggestions-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    display: block;
  }

  .suggestions-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .suggestion-btn {
    font-size: 0.75rem;
    padding: 0.4rem 0.7rem;
    background: rgba(97, 175, 239, 0.1);
    border: 1px solid rgba(97, 175, 239, 0.25);
    border-radius: 15px;
    color: #61afef;
    cursor: pointer;
    transition: all 0.2s;
  }

  .suggestion-btn:hover {
    background: rgba(97, 175, 239, 0.2);
    border-color: #61afef;
    transform: translateY(-1px);
  }

  .chat-input-form {
    display: flex;
    padding: 0.75rem;
    gap: 0.5rem;
    border-top: 1px solid var(--border);
    background: var(--bg);
  }

  .chat-input-form input {
    flex: 1;
    padding: 0.6rem 1rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--bg-card);
    color: var(--text);
    font-size: 0.85rem;
    outline: none;
    transition: border-color 0.2s, background-color 0.3s ease;
  }

  .chat-input-form input::placeholder {
    color: var(--text-muted);
  }

  .chat-input-form input:focus {
    border-color: #61afef;
  }

  .chat-input-form button {
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
  }

  .chat-input-form button svg {
    width: 22px;
    height: 22px;
    color: #c678dd;
    transition: transform 0.3s ease, filter 0.3s ease;
  }

  .chat-input-form button:hover svg {
    transform: translate(3px, -3px) rotate(-12deg);
    filter: drop-shadow(-2px 2px 3px rgba(198, 120, 221, 0.5));
    animation: sendPulse 0.6s ease-in-out infinite;
  }

  .chat-input-form button.sending svg {
    animation: sendLaunch 0.4s ease-out forwards;
  }

  @keyframes sendPulse {
    0%, 100% { transform: translate(3px, -3px) rotate(-12deg) scale(1); }
    50% { transform: translate(4px, -4px) rotate(-12deg) scale(1.1); }
  }

  @keyframes sendLaunch {
    0% { transform: translate(0, 0) rotate(0deg) scale(1); opacity: 1; }
    50% { transform: translate(15px, -15px) rotate(-20deg) scale(0.8); opacity: 0.3; }
    51% { transform: translate(-5px, 5px) rotate(0deg) scale(0.6); opacity: 0; }
    100% { transform: translate(0, 0) rotate(0deg) scale(1); opacity: 1; }
  }

  :global([data-theme="light"]) .chat-input-form button svg {
    color: #8b5cf6;
  }

  :global([data-theme="light"]) .chat-input-form button:hover svg {
    filter: drop-shadow(-2px 2px 3px rgba(139, 92, 246, 0.5));
  }

  @media (max-width: 400px) {
    .chat-panel {
      width: calc(100vw - 2rem);
      right: -0.5rem;
    }
  }
</style>

<script define:vars={{ faqData, responses }}>
  const toggle = document.getElementById('chat-toggle');
  const widget = document.getElementById('chat-widget');
  const form = document.getElementById('chat-form');
  const input = document.getElementById('chat-input');
  const messages = document.getElementById('chat-messages');
  const suggestionsToggle = document.getElementById('suggestions-toggle');
  const suggestionsPanel = document.getElementById('suggestions-panel');

  toggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    widget?.classList.toggle('open');
    if (widget?.classList.contains('open')) {
      input?.focus();
    }
  });

  // Close chat panel when clicking outside
  document.addEventListener('click', (e) => {
    if (widget?.classList.contains('open') && !widget?.contains(e.target)) {
      widget?.classList.remove('open');
    }
  });

  // Suggestions toggle
  suggestionsToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    suggestionsToggle.classList.toggle('active');
    suggestionsPanel?.classList.toggle('show');
  });

  // Close suggestions panel when clicking elsewhere in chat
  const chatPanel = document.getElementById('chat-panel');
  chatPanel?.addEventListener('click', (e) => {
    const target = e.target;
    // Don't close if clicking on the toggle or inside the panel
    if (!suggestionsToggle?.contains(target) && !suggestionsPanel?.contains(target)) {
      suggestionsToggle?.classList.remove('active');
      suggestionsPanel?.classList.remove('show');
    }
  });

  // Handle suggestion button clicks (both inline and panel)
  function handleSuggestionClick(e) {
    const btn = e.target.closest('[data-question]');
    if (btn && input && form) {
      e.stopPropagation();
      input.value = btn.dataset.question;
      // Close suggestions panel if open
      suggestionsToggle?.classList.remove('active');
      suggestionsPanel?.classList.remove('show');
      // Auto-submit the question
      form.requestSubmit();
    }
  }

  messages?.addEventListener('click', handleSuggestionClick);

  function findResponse(query) {
    const lower = query.toLowerCase();

    for (const [category, keywords] of Object.entries(faqData)) {
      if (keywords.some(keyword => lower.includes(keyword))) {
        return responses[category];
      }
    }

    return responses.unknown;
  }

  function addMessage(content, isUser = false) {
    const div = document.createElement('div');
    div.className = `message ${isUser ? 'user' : 'bot'}`;

    const contentDiv = document.createElement('div');
    contentDiv.className = 'message-content';

    // Convert markdown-style formatting
    const formatted = content
      .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
      .replace(/\n/g, '<br>');

    contentDiv.innerHTML = formatted;
    div.appendChild(contentDiv);
    messages?.appendChild(div);
    messages?.scrollTo({ top: messages.scrollHeight, behavior: 'smooth' });
  }

  const submitBtn = form?.querySelector('button[type="submit"]');

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const query = input?.value.trim();
    if (!query) return;

    // Trigger send animation
    submitBtn?.classList.add('sending');
    setTimeout(() => submitBtn?.classList.remove('sending'), 400);

    addMessage(query, true);
    input.value = '';

    // Simulate typing delay
    setTimeout(() => {
      const response = findResponse(query);
      addMessage(response);
    }, 400);
  });
</script>
